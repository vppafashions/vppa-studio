# GEMINI_API_KEY: Used ONLY for image-to-text analysis (analyzeApparel).
# Image generation goes through Runware (see RUNWARE_API_KEY).
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# RUNWARE_API_KEY: Required for image generation via Runware's hosted
# Nano Banana 2 Lite model (`google:nano-banana@2-lite`). Get one at https://my.runware.ai
RUNWARE_API_KEY="MY_RUNWARE_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
